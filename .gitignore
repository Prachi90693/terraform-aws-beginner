# Local Terraform files
.terraform/
.terraform.lock.hcl

# State files - never commit these
terraform.tfstate
terraform.tfstate.backup

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
